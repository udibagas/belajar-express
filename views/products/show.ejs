<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
  </head>
  <body>
    <h1><%= product.name %></h1>

    <table border="1">
      <tbody>
        <tr>
          <th>Category</th>
          <td><%= product.category %></td>
        </tr>
        <tr>
          <th>Price</th>
          <td><%= product.price %></td>
        </tr>
        <tr>
          <th>Stock</th>
          <td><%= product.stock %></td>
        </tr>
        <tr>
          <th>Description</th>
          <td><%= product.description %></td>
        </tr>
      </tbody>
    </table>
  </body>
</html>
